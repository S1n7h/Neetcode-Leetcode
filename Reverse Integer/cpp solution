class Solution {
public:
    int reverse(int x) {
        int a = 0;
        while ( x != 0 ){
            if ( (a > INT_MAX / 10) || (a < INT_MIN / 10))
                return 0;            
            printf("X is: %d\n",x);
            a = a*10 + x%10;
            x = x/10;
            printf("A is: %d\n",a);
        }
        if (x<0){
            a = -a;
        }
        return a;
    }
};