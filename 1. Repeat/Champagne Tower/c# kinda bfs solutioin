public class Solution {
    public double ChampagneTower(int poured, int query_row, int query_glass) {
        //set the previous row
        var prev_row = new List<double>();

        //add poured into the first row
        prev_row.Add(poured);

        //since first row is already added, you start from the next row which is the 2nd row ie row = 1
        for (int row = 1 ; row < query_row + 1 ; row++){
            var curr_row = new List<double>(prev_row.Count + 1);
            for(int i = 0 ; i < prev_row.Count + 1 ; i++)   curr_row.Add(0.0);
            for (int c = 0 ; c < prev_row.Count; c++){
                if (prev_row[c] > 1.0){
                    var extra = (prev_row[c] - 1) * 0.5;
                    curr_row[c] += extra;
                    curr_row[c + 1] += extra;
                }
            }prev_row = curr_row;
        }

        return Math.Min(1, prev_row[query_glass]);
    }
}